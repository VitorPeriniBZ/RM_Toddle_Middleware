# ============================================================
# TOTVS RM Educacional (API TTALK) - {host}/api/educational/v1
# ============================================================
# Host do servidor de APIs do RM da escola (on-premise / cloud privado)
TOTVS_RM_HOST=https://meurm.escola.com.br:8051
# Valor COMPLETO do header Authorization (Basic/token, conforme o ambiente)
TOTVS_RM_AUTH_HEADER=Basic dXN1YXJpbzpzZW5oYQ==
TOTVS_RM_PAGE_SIZE=200
# Códigos de MajorStatus/TermStatus considerados "aluno ativo" (CSV).
# Os domínios NÃO são documentados nos specs - levante no seu ambiente.
# Vazio = aceita todos os contextos.
RM_ACTIVE_TERM_STATUSES=

# ============================================================
# Banco do RM (SQL Server) - usado no Fluxo 2 e no enriquecimento
# do Fluxo 1 (email/dob/genero, que a API de contextos nao traz).
# Se ficar vazio, o enriquecimento e pulado (campos opcionais no Toddle).
# ============================================================
RM_SQL_SERVER=
RM_SQL_PORT=1433
RM_SQL_DATABASE=CorporeRM
RM_SQL_USER=
RM_SQL_PASSWORD=
RM_SQL_ENCRYPT=true
RM_SQL_TRUST_CERT=true
RM_CODCOLIGADA=1

# ============================================================
# Toddle Open API V2 (Toddle 1.0)
# ============================================================
# Regiao do tenant (eu-west-1, us-east-1, eu-central-1, ap-southeast-2, ap-southeast-1, cn-north-1)
TODDLE_REGION=us-east-1
# Opcional: sobrescreve a URL completa (senao e montada pela regiao)
TODDLE_BASE_URL=
# Bearer token fornecido pela equipe do Toddle a escola
TODDLE_TOKEN=
# GET /students exige paginacao; pageSize entre 100 e 400
TODDLE_PAGE_SIZE=400
# Fallback quando nao houver mapeamento YEAR_GROUP na id_mapping
TODDLE_DEFAULT_YEAR_GROUP_ID=

# ============================================================
# Integracao
# ============================================================
# Prefixo do sourceId enviado ao Toddle (ex.: "1-" para prefixar a coligada).
# Escolha UM formato e NUNCA mude - e ele que garante o upsert idempotente.
SOURCE_ID_PREFIX=
SYNC_BATCH_SIZE=50
# Cron da sincronizacao noturna de alunos
STUDENTS_SYNC_CRON=0 3 * * *

# ============================================================
# Infra do middleware
# ============================================================
DATABASE_URL=postgres://middleware:middleware@localhost:5432/rm_toddle
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
NODE_ENV=development
